# ==================== MySQL ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=agent_db

# ==================== JWT ====================
JWT_SECRET_KEY=change-this-to-a-random-secret-key
